---
import Layout from '../../layout/layout.astro';
import '../../styles/carousel.scss';

import projectsData from '../../data/projects.json';

export async function getStaticPaths() {
    return projectsData.projects.map((project) => {
        return {
            params: { id: project.ID.toString() }, 
            props: { project },
        };
    });
}

const { project } = Astro.props;
---

<Layout title={`${project.Title} — Selector0073`}>
    <article class="project-page">
        <header class="project-hero">
            <div class="hero-content text-container mt-4 d-inline-block">
                <div class="badge">{project.Type} • {project.Status}</div>
                <h1>{project.Title}</h1>
                <p class="lead">{project.FullDescription}</p>
                {project.Link && (
                    <a href={project.Link} target="_blank" class="btn-github" rel="noopener noreferrer">
                        <img src="https://img.shields.io/badge/github-%23121011.svg?style=for-the-badge&logo=github&logoColor=white" height="50vh" alt="GitHub repo" />
                    </a>
                )}
            </div>

            <div class="hero-image">
                <img 
                    src={`/images/${project.Images[0]}`} 
                    alt={`Main image: ${project.Title}`}
                    loading="eager"
                />
            </div>
        </header>

        {project.Images.length > 1 && (
            <section class="screenshots">
                <h2 class="text-container mt-4 d-inline-block">Screenshots</h2>
                <div id="carouselExample" class="carousel slide custom-carousel">
                    <div class="carousel-inner">
                        {project.Images.map((image: string, index: number) => (
                            <div class={`carousel-item ${index === 0 ? 'active' : ''}`}>
                                <img src={`/images/${image}`} class="carousel-img" alt={`Скріншот ${index + 1}`} />
                            </div>
                        ))}
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div> 
            </section>
        )}

        <section class="tools">
            <h2 class="text-container mt-4 d-inline-block">Tools</h2>
            <div class="tools-grid">
                {project.Tools.map((tool) => (
                    <div class="tool-card">
                        <strong>{tool.name}</strong>
                        {tool.values && <span> - {tool.values.join(', ')}</span>}
                    </div>
                ))}
            </div>
        </section>
    </article>
</Layout>