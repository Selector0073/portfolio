---
import Layout from '../layout/layout.astro';
import '../styles/skills.scss';
import dataSkills from '../data/skills.json';
import dataProjects from '../data/projects.json';
---

<Layout>
    <div class="d-flex align-items-center logo-header-container">
        <div class="p-0 m-0 logo-wrapper">
            <img src="/favicon.svg" class="mb-3 responsive-logo" alt="Favicon" />
        </div>
        <div class="p-0 m-0 ms-3 text-wrapper">
            <h1><span>Selector</span> <span>0073</span></h1>
            <h2>Fullstack web developer</h2>
        </div>
    </div>


    <div class="text-container mt-4">
        <h2 class="tab" id="AboutScroll">About</h2>
        <p>I am a Full-Stack Developer who builds scalable digital solutions with a focus on clean architecture and absolute control over the codebase. While I leverage AI-assisted tools to maximize efficiency, I firmly reject "vibe-coding" - every line of logic is thoroughly analyzed, optimized, and tested. I operate at my best in high-stress, fast-paced environments.</p>
    </div>


    <h2 class="tab text-container mt-4 d-inline-block" id="SkillsScroll">Skills</h2>
    <div class="skills-wrapper">
        {dataSkills.skills.map((group) => (
            <div class="skill-box">
                <h3>{group.category}</h3>
                <div class="container-fluid text-start">
                    <div class="d-flex flex-wrap gap-3">
                        {group.items.map((skill) => (
                            <div class="skill-capsule">
                                <img src={skill.logo} class="skill-logo" alt={skill.name} />
                                <span class="skill-name">{skill.name}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        ))}
    </div>



    <h2 class="tab text-container mt-4 d-inline-block" id="ProjectsScroll">Projects</h2>
    <div 
        class="d-flex flex-nowrap overflow-auto pb-3" 
        style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;"
    >
        {dataProjects.projects.map((project) => (
            <div 
                class="card card-glass flex-shrink-0 me-3" 
                style="width: 18rem; scroll-snap-align: start;"
            >
                <img 
                    src={`/images/${project.Images[0]}`} 
                    class="card-img-top" 
                    alt={project.Title} 
                    style="height: 200px; object-fit: cover; object-position: center;"
                />
                <div class="card-body">
                    <h3 class="card-title h5">{project.Title}</h3>
                    <p class="card-text">{project.ShortDescription}</p>
                    <a href={`/project/${project.ID}`} class="btn btn-secondary">View more</a>
                </div>
            </div>
        ))}
    </div>
</Layout>
